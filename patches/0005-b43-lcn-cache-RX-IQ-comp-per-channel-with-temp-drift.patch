From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: A4100N LCN port <you@example.org>
Date: Thu, 11 Jun 2026 11:42:10 +0000
Subject: [PATCH 5/5] b43: lcn: cache RX-IQ comp per channel with temp-drift
 invalidation

The RX-IQ calibration added in the previous patch runs the full
lna2/tia/biq1 gain search and tone measurement every time it is invoked
(brcmsmac's module==1 path; the module==2 "apply stored coefficients"
path is dead code there and the LCN driver ships no static table). Every
channel visit therefore re-ran the ~ms-long measurement.

Add a per-channel coefficient cache, populated at runtime: after a
measurement, wlc_lcnphy_calc_rx_iq_comp()'s {a0,b0} (now stored, as
brcmsmac does in lcnphy_cal_results) are kept per channel together with
the tempsense reading at cal time. On a later visit the stored
coefficients are re-applied directly (six PHY writes, no MAC suspend, no
tone) unless the temperature has drifted past 60 tempsense units --
brcmsmac's PHY_PERICAL_WATCHDOG threshold -- in which case the channel is
re-measured.

Wiring:
 - op_init() runs the cal once, after the PHY is fully configured, then
   marks the cache live;
 - op_switch_channel() applies-or-measures the new channel (guarded so the
   mid-init channel switch does not cal prematurely);
 - a new pwork_60sec op re-checks the current channel so drift is caught
   while parked on one channel, matching brcmsmac's watchdog cadence.

b43_phy_lcn_tempsense() is the wl mode-1 read: it triggers a fresh
conversion through b43_phy_lcn_sense_setup() and reads 0x476/0x477. Open
loop has no tx-power-control loop refreshing those regs, so a mode-0 read
would be stale. The absolute value stays uncalibrated
(lcnphy_tempsense_option is SPROM-derived and unparsed); only the delta
gates re-cal. Each entry is invalidated against its own cal-time
temperature, so a temperature change invalidates channels independently
on next visit rather than flushing the whole table.

NOT validated on hardware. Part of the LCN-PHY (BCM4313) bring-up for
the A4100N.

Signed-off-by: A4100N LCN port <you@example.org>
---
 drivers/net/wireless/broadcom/b43/phy_lcn.c | 116 ++++++++++++++++++--
 drivers/net/wireless/broadcom/b43/phy_lcn.h |  12 ++
 2 files changed, 120 insertions(+), 8 deletions(-)

diff --git a/drivers/net/wireless/broadcom/b43/phy_lcn.c b/drivers/net/wireless/broadcom/b43/phy_lcn.c
index 1697367..25b3564 100644
--- a/drivers/net/wireless/broadcom/b43/phy_lcn.c
+++ b/drivers/net/wireless/broadcom/b43/phy_lcn.c
@@ -1127,6 +1127,10 @@ cleanup:
 	b43_phy_maskset(dev, 0x64b, (u16)~(0x1 << 0), 1 << 0);
 	b43_phy_maskset(dev, 0x64b, (u16)~(0x1 << 3), 1 << 3);
 
+	/* brcmsmac lcnphy_cal_results.rxiqcal_coeff_a0/b0 (cache source) */
+	dev->phy.lcn->rxiqcal_coeff_a0 = a0_new;
+	dev->phy.lcn->rxiqcal_coeff_b0 = b0_new;
+
 	return result;
 }
 
@@ -1301,20 +1305,88 @@ stop_tone:
 	b43_phy_lcn_rx_gain_override_enable(dev, false);
 }
 
+/* LCNPHY_TEMPSENSE(): raw tempsense value -> signed reading */
+#define B43_LCN_TEMPSENSE(v)	((s16)(((v) > 255) ? ((int)(v) - 512) : (int)(v)))
+
+/*
+ * Re-measure a cached channel once its temperature has drifted this far from
+ * the reading taken when it was calibrated. Matches brcmsmac's watchdog
+ * threshold (wlc_lcnphy_calib_modes(PHY_PERICAL_WATCHDOG): |temp_diff| > 60).
+ */
+#define B43_LCN_RXIQ_TEMP_DELTA	60
+
 /*
- * wlc_lcnphy_calib_modes(PHY_PERICAL_PHYINIT) -> wlc_lcnphy_periodic_cal().
- * Phase-1 RX spine only: TX IQLO cal and the TSSI table fill (closed-loop
- * tx-power) are Phase 2.
+ * wlc_lcnphy_tempsense(pi, 1): trigger a fresh conversion and read it. Open
+ * loop has no tx-power-control loop refreshing the tempsense regs, so a mode-0
+ * read would see a stale value; set up the AFE/ADC via b43_phy_lcn_sense_setup()
+ * (which runs a dummy frame) and read the result from 0x476/0x477. Returns the
+ * raw value; callers compare via B43_LCN_TEMPSENSE(). lcnphy_tempsense_option is
+ * SPROM-derived and not parsed in Phase 1 (assumed 0); only the
+ * hw_pwr_ctl_capable branch is kept, so the absolute reading is uncalibrated --
+ * only the delta gates re-cal.
  */
-static void b43_phy_lcn_calib(struct b43_wldev *dev)
+static u16 b43_phy_lcn_tempsense(struct b43_wldev *dev)
 {
-	b43_mac_suspend(dev);
+	u16 v1, v2;
+	s32 avg;
+
+	b43_phy_lcn_sense_setup(dev, B43_SENSE_TEMP);
+
+	v1 = b43_phy_read(dev, 0x476) & 0x1ff;
+	v2 = b43_phy_read(dev, 0x477) & 0x1ff;
 
+	avg = (v1 > 255) ? ((s32)v1 - 512) : (s32)v1;
+
+	if (dev->phy.lcn->hw_pwr_ctl_capable) {
+		avg += (v2 > 255) ? (512 - (s32)v2) : -(s32)v2;
+	} else {
+		avg += (v2 > 255) ? ((s32)v2 - 512) : (s32)v2;
+		avg /= 2;
+	}
+	if (avg < 0)
+		avg += 512;
+
+	return (u16)avg;
+}
+
+/*
+ * RX-IQ calibration for the current channel, with a per-channel coefficient
+ * cache (the brcmsmac module == 2 "apply from table" path, populated at runtime
+ * instead of from a static table -- the LCN driver ships none). On a cache hit
+ * whose calibration temperature has not drifted past B43_LCN_RXIQ_TEMP_DELTA the
+ * stored {a, b} are re-applied directly (no MAC suspend, no tone); otherwise the
+ * full measurement runs and (re)populates the entry.
+ */
+static void b43_phy_lcn_rx_iqcal_for_channel(struct b43_wldev *dev)
+{
+	struct b43_phy_lcn *lcn = dev->phy.lcn;
+	u8 chan = dev->phy.channel;
+	struct b43_lcn_rx_iqcomp *e;
+	u16 temp_now;
+
+	if (chan < 1 || chan > ARRAY_SIZE(lcn->rx_iqcomp))
+		return;
+	e = &lcn->rx_iqcomp[chan - 1];
+
+	temp_now = b43_phy_lcn_tempsense(dev);
+
+	if (e->valid &&
+	    abs(B43_LCN_TEMPSENSE(temp_now) - B43_LCN_TEMPSENSE(e->temp)) <=
+	    B43_LCN_RXIQ_TEMP_DELTA) {
+		b43_phy_lcn_set_rx_iq_comp(dev, e->a, e->b);
+		return;
+	}
+
+	b43_mac_suspend(dev);
 	b43_phy_lcn_deaf_mode(dev, true);
 	b43_phy_lcn_rx_iq_cal(dev);
 	b43_phy_lcn_deaf_mode(dev, false);
-
 	b43_mac_enable(dev);
+
+	e->a = lcn->rxiqcal_coeff_a0;
+	e->b = lcn->rxiqcal_coeff_b0;
+	e->temp = temp_now;
+	e->valid = true;
 }
 
 /**************************************************
@@ -1392,7 +1464,8 @@ static int b43_phy_lcn_op_init(struct b43_wldev *dev)
 
 	/* TODO */
 
-	b43_phy_lcn_calib(dev);
+	b43_phy_lcn_rx_iqcal_for_channel(dev);
+	dev->phy.lcn->rx_iqcal_init_done = true;
 
 	return 0;
 }
@@ -1436,6 +1509,7 @@ static int b43_phy_lcn_op_switch_channel(struct b43_wldev *dev,
 	struct ieee80211_channel *channel = dev->wl->hw->conf.chandef.chan;
 	enum nl80211_channel_type channel_type =
 		cfg80211_get_chandef_type(&dev->wl->hw->conf.chandef);
+	int err;
 
 	if (b43_current_band(dev->wl) == NL80211_BAND_2GHZ) {
 		if ((new_channel < 1) || (new_channel > 14))
@@ -1444,7 +1518,32 @@ static int b43_phy_lcn_op_switch_channel(struct b43_wldev *dev,
 		return -EINVAL;
 	}
 
-	return b43_phy_lcn_set_channel(dev, channel, channel_type);
+	err = b43_phy_lcn_set_channel(dev, channel, channel_type);
+	if (err)
+		return err;
+
+	/*
+	 * Apply the cached RX-IQ comp for the new channel (or measure and cache
+	 * it on first visit / temperature drift). Skipped during init: op_init()
+	 * runs its own cal once the PHY is fully configured, while the channel
+	 * switch it issues happens mid-setup.
+	 */
+	if (dev->phy.lcn->rx_iqcal_init_done)
+		b43_phy_lcn_rx_iqcal_for_channel(dev);
+
+	return 0;
+}
+
+/*
+ * Periodic watchdog: re-evaluate the current channel.
+ * b43_phy_lcn_rx_iqcal_for_channel() re-measures only if the temperature has
+ * drifted past the threshold, otherwise it is a cheap re-apply. Mirrors
+ * brcmsmac's PHY_PERICAL_WATCHDOG cadence.
+ */
+static void b43_phy_lcn_op_pwork_60sec(struct b43_wldev *dev)
+{
+	if (dev->phy.lcn->rx_iqcal_init_done)
+		b43_phy_lcn_rx_iqcal_for_channel(dev);
 }
 
 static unsigned int b43_phy_lcn_op_get_default_chan(struct b43_wldev *dev)
@@ -1507,6 +1606,7 @@ const struct b43_phy_operations b43_phyops_lcn = {
 	.software_rfkill	= b43_phy_lcn_op_software_rfkill,
 	.switch_analog		= b43_phy_lcn_op_switch_analog,
 	.switch_channel		= b43_phy_lcn_op_switch_channel,
+	.pwork_60sec		= b43_phy_lcn_op_pwork_60sec,
 	.get_default_chan	= b43_phy_lcn_op_get_default_chan,
 	.recalc_txpower		= b43_phy_lcn_op_recalc_txpower,
 	.adjust_txpower		= b43_phy_lcn_op_adjust_txpower,
diff --git a/drivers/net/wireless/broadcom/b43/phy_lcn.h b/drivers/net/wireless/broadcom/b43/phy_lcn.h
index 29d9483..d14abd9 100644
--- a/drivers/net/wireless/broadcom/b43/phy_lcn.h
+++ b/drivers/net/wireless/broadcom/b43/phy_lcn.h
@@ -19,11 +19,23 @@
 #define B43_PHY_LCN_RF_CTL7			B43_PHY_OFDM(0x0FA)
 
 
+/* Per-channel RX-IQ compensation cache entry (a/b coeffs + cal temp) */
+struct b43_lcn_rx_iqcomp {
+	u16 a;
+	u16 b;
+	u16 temp;
+	bool valid;
+};
+
 struct b43_phy_lcn {
 	bool hw_pwr_ctl;
 	bool hw_pwr_ctl_capable;
 	u8 tx_pwr_curr_idx;
 	bool spurmod;
+	bool rx_iqcal_init_done;
+	u16 rxiqcal_coeff_a0;
+	u16 rxiqcal_coeff_b0;
+	struct b43_lcn_rx_iqcomp rx_iqcomp[14];
 };
 
 
-- 
2.43.0

